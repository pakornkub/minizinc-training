%% Data: Flexible Job Shop — 3 jobs, 2 tasks, 3 machines
%% 0 = เครื่องนั้นทำ task นี้ไม่ได้
JOB     = J(1..3);
TASK    = T(1..2);
MACHINE = { M1, M2, M3 };

%% dur[job, task, machine]
dur = array3d(JOB, TASK, MACHINE, [
  %% Job1 Task1: M1=10, M2=8,  M3=0 (ทำไม่ได้)
  10, 8, 0,
  %% Job1 Task2: M1=0,  M2=12, M3=7
   0,12, 7,
  %% Job2 Task1: M1=6,  M2=0,  M3=9
   6, 0, 9,
  %% Job2 Task2: M1=14, M2=10, M3=0
  14,10, 0,
  %% Job3 Task1: M1=8,  M2=11, M3=5
   8,11, 5,
  %% Job3 Task2: M1=0,  M2=6,  M3=9
   0, 6, 9
]);
