%% Data: 5 พยาบาล, 14 วัน
n_nurses          = 5;
n_days            = 14;
min_night_shifts  = 3;

%% req[day, shift]: D=1, E=2, N=3
%% วันธรรมดา (D1-D10): D≥2, E≥1, N≥1
%% สุดสัปดาห์ (D11-D14): D≥1, E≥1, N≥1
req = array2d(1..14, 1..3, [
  2,1,1,  2,1,1,  2,1,1,  2,1,1,  2,1,1,  % สัปดาห์แรก D1-D5
  1,1,1,  1,1,1,                            % D6-D7 (วันหยุด)
  2,1,1,  2,1,1,  2,1,1,  2,1,1,  2,1,1,  % D8-D12
  1,1,1,  1,1,1                             % D13-D14
]);
