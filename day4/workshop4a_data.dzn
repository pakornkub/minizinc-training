%% Data: Flexible Job Shop — โรงงานโลหะ
%% 4 orders, 3 ขั้นตอน, 3 เครื่องจักร
%%
%% Tasks: Cutting (ตัด), Welding (เชื่อม), Finishing (ขัดผิว)
%% Machines:
%%   MA = เครื่องเลเซอร์     (ตัด 6 นาที, ขัดผิว 8 นาที, เชื่อมไม่ได้)
%%   MB = หุ่นยนต์เชื่อม     (เชื่อม 7 นาที เท่านั้น)
%%   MC = เครื่องอเนกประสงค์ (ทำได้ทุกอย่าง แต่ช้ากว่า)
%%
%% รันด้วย: minizinc workshop4a_starter.mzn workshop4a_data.dzn

JOB     = { OrderA, OrderB, OrderC, OrderD };
TASK    = { Cutting, Welding, Finishing };
MACHINE = { MA, MB, MC };

%%                       MA     MB     MC
capable = array2d(TASK, MACHINE, [
  true,  false, true,    %% Cutting:  MA✓  MB✗  MC✓
  false, true,  true,    %% Welding:  MA✗  MB✓  MC✓
  true,  false, true     %% Finishing:MA✓  MB✗  MC✓
]);

%%                          MA   MB   MC
proc_time = array2d(TASK, MACHINE, [
   6,   0,   9,    %% Cutting:   MA=6นาที  (MB ทำไม่ได้)  MC=9นาที
   0,   7,  10,    %% Welding:   (MA ทำไม่ได้)  MB=7นาที  MC=10นาที
   8,   0,   6     %% Finishing: MA=8นาที  (MB ทำไม่ได้)  MC=6นาที
]);

%% หมายเหตุ:
%%   MB ทำได้เฉพาะ Welding — ถ้างาน Welding 4 ออร์เดอร์ต้องผ่าน MB ทั้งหมด
%%   MC เป็น bottleneck — ทำได้ทุกอย่างแต่ช้า
%%   MC อาจต้องรับงาน Welding บางออร์เดอร์แทน MB เพื่อลด makespan
