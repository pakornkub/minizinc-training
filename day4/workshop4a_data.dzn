%% Data: 4 ออร์เดอร์, 3 ขั้นตอน, 3 เครื่อง
%% 0 = เครื่องนั้นทำ task นี้ไม่ได้
JOB     = J(1..4);
TASK    = T(1..3);
MACHINE = { MA, MB, MC };

%% dur[job, task, machine] — นาที (0 = ไม่สามารถใช้เครื่องนี้)
dur = array3d(JOB, TASK, MACHINE, [
  %% J1: T1        T2        T3
  8, 10,  0,    0, 12,  7,   6,  0,  9,
  %% J2
  5,  0,  8,   10,  8,  0,   0, 11,  7,
  %% J3
  0,  9,  6,    8,  0, 10,   9, 12,  0,
  %% J4
 11,  8,  0,    0,  9,  6,   7,  0, 10
]);
