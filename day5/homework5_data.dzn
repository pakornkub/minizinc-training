%% Data: 6 ลูกค้า, 2 รถ, 10 รายการอะไหล่

n_customers = 6;
n_vehicles  = 2;
weight_cap  = 80;   % กก./คัน

demand = [20, 35, 15, 40, 25, 30];  % ลูกค้า 1-6

%% n_nodes = 6+2 = 8  (1-6: ลูกค้า, 7-8: depot)
dist = array2d(1..8, 1..8, [
%%  C1  C2  C3  C4  C5  C6  D1  D2
    0, 12,  8, 18, 10, 14,  5,  5,   % C1
   12,  0,  9, 11, 16,  7,  8,  8,   % C2
    8,  9,  0, 15,  6, 18,  6,  6,   % C3
   18, 11, 15,  0,  9, 10,  9,  9,   % C4
   10, 16,  6,  9,  0, 12,  7,  7,   % C5
   14,  7, 18, 10, 12,  0, 11, 11,   % C6
    5,  8,  6,  9,  7, 11,  0,  0,   % D1
    5,  8,  6,  9,  7, 11,  0,  0    % D2
]);

%% Packing
n_items = 10;
box_cap = 25;   % กก./กล่อง

item_weight = [8, 12, 5, 15, 7, 10, 3, 18, 6, 9];

fragile_items = {1, 3, 7};    % อะไหล่แตกง่าย (index)
heavy_items   = {4, 6, 8};    % อะไหล่หนัก
